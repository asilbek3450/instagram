# ==========================================
# Railway Environment Variables Template
# ==========================================

# 1. Flask Core Settings
# Set this to a long random string for production
SECRET_KEY=your-super-secret-key
# Set to False in production
DEBUG=False

# 2. Database
# Railway will automatically provide DATABASE_URL if you add a PostgreSQL plugin.
# E.g., DATABASE_URL=postgresql://user:pass@containers-us-west-XX.railway.app:5432/railway
DATABASE_URL=

# 3. JWT Security
JWT_SECRET_KEY=your-jwt-secret-key
JWT_COOKIE_SECURE=True
JWT_COOKIE_CSRF_PROTECT=True

# 4. Redis & Celery (Optional for Background Tasks)
# Railway will provide REDIS_URL if you add a Redis plugin.
# REDIS_URL=redis://default:pass@containers-us-west-XX.railway.app:6379
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# 5. APIs (RapidAPI for Downloader, Anthropic for AI)
RAPIDAPI_KEY=your-rapidapi-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# 6. Telegram bot (downloader) — token from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# 7. Telegram Bot Webhook (Railway production)
# Railway'da domeningizni kiriting — bot webhook orqali ishlaydi (cold-start yo'q)
# Masalan: WEBHOOK_HOST=https://instagram.mirolimov.uz
WEBHOOK_HOST=https://your-domain.railway.app
